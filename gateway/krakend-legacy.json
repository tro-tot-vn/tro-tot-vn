{
    "version": 3,
    "name": "TroTotVN Gateway - Legacy Mode",
    "port": 8000,
    "cache_ttl": "300s",
    "timeout": "3s",
    "extra_config": {
        "telemetry/logging": {
            "level": "INFO",
            "prefix": "[LEGACY-GATEWAY]",
            "stdout": true
        },
        "security/cors": {
            "allow_origins": [
                "*"
            ],
            "allow_methods": [
                "GET",
                "POST",
                "PUT",
                "DELETE",
                "PATCH",
                "OPTIONS"
            ],
            "allow_headers": [
                "Origin",
                "Authorization",
                "Content-Type"
            ],
            "max_age": "12h"
        }
    },
    "endpoints": [
        {
            "endpoint": "/v1/auth/login",
            "method": "POST",
            "backend": [
                {
                    "url_pattern": "/v1/auth/login",
                    "host": [
                        "http://monolith:3333"
                    ]
                }
            ]
        },
        {
            "endpoint": "/v1/auth/register",
            "method": "POST",
            "backend": [
                {
                    "url_pattern": "/v1/auth/register",
                    "host": [
                        "http://monolith:3333"
                    ]
                }
            ]
        },
        {
            "endpoint": "/v1/{all_paths}",
            "method": "GET",
            "extra_config": {
                "auth/validator": {
                    "alg": "HS256",
                    "key": "6cf9d57d-7d6c-4ab5-8419-115ec872aabf",
                    "propagate_claims": [
                        [
                            "accountId",
                            "X-User-Id"
                        ]
                    ]
                }
            },
            "backend": [
                {
                    "url_pattern": "/v1/{all_paths}",
                    "host": [
                        "http://monolith:3333"
                    ]
                }
            ]
        },
        {
            "endpoint": "/v1/{all_paths}",
            "method": "POST",
            "extra_config": {
                "auth/validator": {
                    "alg": "HS256",
                    "key": "6cf9d57d-7d6c-4ab5-8419-115ec872aabf",
                    "propagate_claims": [
                        [
                            "accountId",
                            "X-User-Id"
                        ]
                    ]
                }
            },
            "backend": [
                {
                    "url_pattern": "/v1/{all_paths}",
                    "host": [
                        "http://monolith:3333"
                    ]
                }
            ]
        },
        {
            "endpoint": "/chat/rooms",
            "method": "GET",
            "extra_config": {
                "auth/validator": {
                    "alg": "HS256",
                    "key": "6cf9d57d-7d6c-4ab5-8419-115ec872aabf",
                    "propagate_claims": [
                        [
                            "accountId",
                            "X-User-Id"
                        ]
                    ]
                }
            },
            "backend": [
                {
                    "url_pattern": "/chat/rooms",
                    "host": [
                        "http://chat-service:8083"
                    ]
                }
            ]
        }
    ]
}